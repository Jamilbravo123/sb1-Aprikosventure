# ============================================================
# Environment Variables — [Project Name]
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# For secret values, see the secrets registry table below.
#
# Legend:
#   [PUBLIC]    — Safe to expose in client-side code
#   [SECRET]    — Never expose, never log
#   [CONFIG]    — Non-sensitive configuration
# ============================================================

# --- Application ---
NODE_ENV=development                              # [CONFIG] development | production
NEXT_PUBLIC_SITE_URL=http://localhost:3000         # [PUBLIC] Base URL

# --- Database ---
DATABASE_URL=                                     # [SECRET] PostgreSQL connection string

# --- Auth (see SECURITY.md §2 for auth model) ---
# SUPABASE_URL=https://your-project.supabase.co   # [PUBLIC] Supabase project URL
# SUPABASE_ANON_KEY=                               # [PUBLIC] Supabase anon/public key
# SUPABASE_SERVICE_ROLE_KEY=                       # [SECRET] Supabase service role key
# AUTH_SECRET=                                     # [SECRET] NextAuth/session secret

# --- Third-Party APIs ---
# STRIPE_SECRET_KEY=                               # [SECRET] Stripe API key
# STRIPE_WEBHOOK_SECRET=                           # [SECRET] Stripe webhook signing secret
# SENDGRID_API_KEY=                                # [SECRET] SendGrid email API key

# --- AI ---
# ANTHROPIC_API_KEY=                               # [SECRET] Claude API key
# OPENAI_API_KEY=                                  # [SECRET] OpenAI API key

# ============================================================
# Secrets Registry
# ============================================================
# | Variable                  | Where to Get              | Format       |
# |---------------------------|---------------------------|--------------|
# | DATABASE_URL              | Supabase Dashboard > DB   | postgres://  |
# | SUPABASE_SERVICE_ROLE_KEY | Supabase > Settings > API | eyJ... JWT   |
# | AUTH_SECRET               | Generate: openssl rand -base64 32 |      |
# | STRIPE_SECRET_KEY         | Stripe Dashboard > API    | sk_...       |
# | ANTHROPIC_API_KEY         | Anthropic Console         | sk-ant-...   |
# ============================================================
